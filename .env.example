# Copia este ficheiro para .env e preenche os valores
# cp .env.example .env

# Base de dados SQLite (não alteres o caminho, é relativo à pasta prisma/)
DATABASE_URL="file:./dev.db"

# Google Calendar OAuth (opcional - só necessário para integração com Google Calendar)
# Obtém as credenciais em: https://console.cloud.google.com/
# 1. Cria um projeto e ativa a Google Calendar API
# 2. Cria credenciais OAuth 2.0 (tipo: Desktop App)
# 3. Preenche os valores abaixo
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3210/api/auth/google/callback"
